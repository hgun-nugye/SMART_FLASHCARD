<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="12dp"
    android:layout_marginVertical="4dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="0dp"
    app:strokeWidth="0.5dp"
    app:strokeColor="#E0E0E0"
    app:cardBackgroundColor="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:gravity="center_vertical">

        <!-- Icon badge bên trái -->
        <LinearLayout
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_card_badge"
            android:gravity="center"
            android:layout_marginEnd="12dp">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_abc"
                app:tint="#534AB7" />
        </LinearLayout>

        <!-- Nội dung chính -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvFront"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#1A1A1A"
                android:text="msnc"/>

            <TextView
                android:id="@+id/tvBack"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textColor="#666666"
                android:layout_marginTop="2dp"
                android:maxLines="1"
                android:ellipsize="end"
                android:text="csbf"/>

            <TextView
                android:id="@+id/tvIpa"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textColor="#AAAAAA"
                android:layout_marginTop="1dp"
                android:text="cnwjfe"/>
        </LinearLayout>

        <!-- Nút phát âm -->
        <ImageButton
            android:id="@+id/btnPlayCard"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/bg_tts_button"
            android:src="@android:drawable/ic_btn_speak_now"
            app:tint="#A78BFA"
            android:contentDescription="Nghe phát âm"
            android:layout_marginStart="6dp" />

        <!-- Badge trạng thái + chevron -->
        <LinearLayout
            android:layout_width="60dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_gravity="center_vertical"
            android:layout_marginStart="6dp"
            android:gravity="center_horizontal">

            <TextView
                android:id="@+id/tvStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingHorizontal="8dp"
                android:paddingVertical="3dp"
                android:textSize="10sp"
                android:textStyle="bold"
                android:text="learned"
                android:background="@drawable/bg_status_badge"
                android:layout_marginBottom="6dp" />
        </LinearLayout>

    </LinearLayout>
</androidx.cardview.widget.CardView>